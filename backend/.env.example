# raspi-dashboard backend — local dev config. Copy to backend/.env.
# In prod these come from /etc/secrets/raspi-dashboard.env (../raspi).

# Bypass the oauth2-proxy forward-auth gate with a synthetic user. Dev only.
DEV_AUTH=1

DASHBOARD_BIND=127.0.0.1:3007

# Upstreams. Defaults match the Pi's loopback ports; override to point dev at
# an SSH tunnel (e.g. `ssh -L 3001:127.0.0.1:3001 pi`).
GATUS_URL=http://127.0.0.1:3001
BESZEL_URL=http://127.0.0.1:8091

# Read-only beszel PocketBase user. Unset → /api/metrics reports unavailable.
# BESZEL_USER=dashboard-ro@localhost
# BESZEL_PASSWORD=

# Public, human-facing beszel base URL. Surfaced to the SPA so metrics rows
# deep-link to a system's beszel page (/system/{id}). Unset → rows aren't links.
# BESZEL_PUBLIC_URL=https://beszel.example.com

# Trivy file handshake (shared /var/lib/trivy mount in prod).
TRIVY_SCAN_FILE=/var/lib/trivy/last-scan.json
TRIVY_SCAN_REQUEST=/var/lib/trivy/scan-request
TRIVY_STALE_HOURS=96

# Serve the built SPA. `yarn build` in frontend/ emits to frontend/dist.
STATIC_DIR=../frontend/dist
